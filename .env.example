# =============================================================
# Fub Simulation Configuration
# =============================================================
# This fork runs entirely on local models — no cloud APIs needed.
# Copy this file to .env and adjust values for your setup.
# =============================================================

# ===== RESEARCH / PERSONA LLM (OpenAI-compatible format) =====
# Used by web research, seed synthesis, persona generation, document parsing.
# Low volume, quality-sensitive — use a stronger model here.
# For Docker: use service name "ollama" instead of "localhost"
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b
# Lighter model for development (less VRAM):
# LLM_MODEL_NAME=qwen2.5:14b

# ===== SIMULATION LLM (optional split — falls back to LLM_* above if blank) =====
# Used by the AgentSociety simulation (agent actions): thousands of calls,
# ~94% of total token spend. Use a cheaper/faster model, or local Ollama (free).
# Leave SIM_LLM_API_KEY / SIM_LLM_BASE_URL blank to reuse the research key/base.
# Example cloud split: SIM_LLM_MODEL=qwen3.6-flash-2026-04-16
# Example free local sim: SIM_LLM_BASE_URL=http://localhost:11434/v1 + SIM_LLM_MODEL=qwen2.5:14b
SIM_LLM_MODEL=
SIM_LLM_API_KEY=
SIM_LLM_BASE_URL=

# ===== Graph Database Configuration =====
# GRAPH_BACKEND options:
#   'neo4j'    — Full graph server (requires Docker, best for production)
#   'ladybug'  — Embedded graph DB, fast analytical queries, persists to disk, no Docker
#   'kglite'   — Lightweight in-memory dict (no persistence, dev-only)
GRAPH_BACKEND=neo4j

# Neo4j Configuration (only used when GRAPH_BACKEND=neo4j)
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fubsimulation

# ===== Embedding Configuration =====
# Uses Ollama's embedding endpoint
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434
# For Docker: EMBEDDING_BASE_URL=http://ollama:11434

# ===== AgentSociety2 LLM fallback =====
# agentsociety2 may read OPENAI_API_KEY / OPENAI_API_BASE_URL as a fallback.
# Point these at the same local Ollama server.
OPENAI_API_KEY=ollama
OPENAI_API_BASE_URL=http://localhost:11434/v1

# ===== Docker-mode overrides =====
# Uncomment these when running ALL services inside Docker
# (backend container talks to neo4j/ollama containers by service name)
# LLM_BASE_URL=http://ollama:11434/v1
# NEO4J_URI=bolt://neo4j:7687
# EMBEDDING_BASE_URL=http://ollama:11434
# OPENAI_API_BASE_URL=http://ollama:11434/v1

# ===== Web Research / Agent Enrichment =====
# When FIRECRAWL_API_KEY is set, agent profile generation automatically runs
# iterative deep research (Finance-LLMs/deep-research-python) per archetype
# and injects grounded SA context (statistics, quotes, recent events) into
# persona prompts before generation. Uses your LLM_API_KEY / LLM_BASE_URL /
# LLM_MODEL_NAME — no extra keys needed if you're already using Groq.
#
# Firecrawl — full-page web scraping for deep-research-python
# Get key at: https://firecrawl.dev (free tier available)
# FIRECRAWL_API_KEY=
#
# Serper — Google Search API (used by MCP inline fallback only)
# Get key at: https://serper.dev (free tier: 2500 searches/month)
# SERPER_API_KEY=
#
# Deep web-research MCP server (optional — exposes run_task over MCP on port 8001)
# Start with: python backend/miroflow_mcp_server.py
# WEB_SEARCH_API_URL=http://localhost:8001/mcp/
# WEB_SEARCH_API_TOKEN=
# DEEP_RESEARCH_DEFAULT_LLM=qwen-3
# DEEP_RESEARCH_DEFAULT_AGENT=mirothinker_v1.5_keep5_max200
